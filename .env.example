# LLM — Ollama is used by default (recommended for local use)
# Install Ollama: https://ollama.com — then run: ollama pull qwen2.5:3b
OLLAMA_MODEL=qwen2.5:3b
# OLLAMA_BASE_URL=http://localhost:11434  # default, change if running remotely

# OpenAI — optional fallback if Ollama is not available
# Also required for voice message transcription (Whisper)
# OPENAI_API_KEY=your openai api key

TUYA_ACCESS_ID=your access id
TUYA_ACCESS_SECRET=your access secret
TUYA_API_ENDPOINT=https://openapi.tuyaus.com
# TUYA_DEVICE_ID is optional — use /devices in the bot to discover and select your device
# TUYA_DEVICE_ID=your device id

TELEGRAM_BOT_TOKEN=your telegram bot token

# LangSmith — optional, enables full observability (traces, latency, tool decisions)
# Sign up at https://smith.langchain.com — free tier available
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your langsmith api key
# LANGCHAIN_PROJECT=tuya-vacuum-bot
